# ============================================================
# MARVIN OS — Fichier de configuration
# ============================================================
# Renommez ce fichier en .env avant de démarrer le bot.
# Ne partagez JAMAIS votre fichier .env — il contient vos
# informations sensibles (token, clés, mots de passe).
# ============================================================


# === OBLIGATOIRE ===

# Token de votre bot Discord
# Récupéré depuis : discord.com/developers/applications → Onglet Bot → Reset Token
DISCORD_TOKEN=VOTRE_TOKEN_DISCORD_ICI

# Votre identifiant Discord personnel (pour les alertes vocales)
# Discord en mode développeur → clic droit sur votre avatar → Copier l'identifiant
MY_USER_ID=VOTRE_ID_DISCORD_ICI

# Clé secrète pour les sessions du dashboard (doit être longue et aléatoire)
# Générez-en une avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENEREZ_UNE_CLE_ALEATOIRE_ICI


# === OPTIONNEL — Email SMTP ===
# Permet la récupération de mot de passe du dashboard.
# Sans cette config, la récupération de mot de passe sera désactivée.

# Serveur SMTP (Gmail : smtp.gmail.com / OVH : ssl0.ovh.net)
MAIL_SERVER=

# Port SMTP (587 pour TLS recommandé, 465 pour SSL)
MAIL_PORT=587

# Adresse email expéditeur
MAIL_USERNAME=

# Mot de passe ou clé d'application (Gmail : créez un mot de passe d'application Google)
MAIL_PASSWORD=

# Adresse email qui recevra les liens de réinitialisation
MAIL_RECEIVER=
